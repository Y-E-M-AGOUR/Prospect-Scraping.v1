{
  "manifest_version": 3,
  "name": "TCB Prospect Capture",
  "description": "Capture LinkedIn prospects and append enriched rows to Google Sheets.",
  "version": "0.1.0",
  "action": {
    "default_title": "Capture prospect",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/sales/lead/*",
        "https://www.linkedin.com/sales/people/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
